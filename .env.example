# ============================================================
# ALEJANDRA SALON — Variables de entorno
# Copia este archivo como .env.local y llena los valores
# NUNCA subas .env.local a git
# ============================================================

# ── Supabase (proyecto en supabase.com) ──────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Service Role Key — SOLO en servidor, nunca en el cliente
# La encuentras en Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ── Upstash Redis — rate limiting multi-instancia ─────────────
# Opcional pero recomendado para producción.
# Crea una base gratuita en console.upstash.com
# Si no se configura, cae a rate limiting en memoria (solo una instancia)
UPSTASH_REDIS_REST_URL=https://TU_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=tu_token_aqui

# ── Next.js ──────────────────────────────────────────────────
# En producción Vercel lo detecta automáticamente
# NEXT_PUBLIC_SITE_URL=https://tu-salon.vercel.app
